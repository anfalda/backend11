<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports
              http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="care_coverage"
              pageWidth="595"
              pageHeight="842"
              columnWidth="535"
              leftMargin="30"
              rightMargin="30"
              topMargin="20"
              bottomMargin="20">

    <parameter name="logoPath" class="java.lang.String"/>
    <parameter name="coverageId" class="java.lang.String"/>
    <parameter name="patientLastName" class="java.lang.String"/>
    <parameter name="patientFirstName" class="java.lang.String"/>
    <parameter name="status" class="java.lang.String"/>
    <parameter name="demandeDate" class="java.lang.String"/>
    <parameter name="startDate" class="java.lang.String"/>
    <parameter name="endDate" class="java.lang.String"/>
    <parameter name="hasCancer" class="java.lang.String"/>
    <parameter name="notes" class="java.lang.String"/>
    <parameter name="currentDate" class="java.lang.String"/>

    <queryString><![CDATA[]]></queryString>

    <title>
        <band height="90">

            <!-- Logo top-left -->
            <image scaleImage="RetainShape" hAlign="Left" vAlign="Middle">
                <reportElement x="0" y="0" width="80" height="60"/>
                <imageExpression><![CDATA[$P{logoPath}]]></imageExpression>
            </image>

            <!-- Title centered -->
            <staticText>
                <reportElement x="80" y="10" width="375" height="35"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="18" isBold="true"/>
                </textElement>
                <text><![CDATA[Demande Prise En Charge]]></text>
            </staticText>

            <!-- Date top-right -->
            <staticText>
                <reportElement x="380" y="55" width="60" height="20"/>
                <textElement verticalAlignment="Middle">
                    <font size="10" isBold="true"/>
                </textElement>
                <text><![CDATA[Date:]]></text>
            </staticText>
            <textField>
                <reportElement x="440" y="55" width="95" height="20"/>
                <textElement verticalAlignment="Middle">
                    <font size="10"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{currentDate}]]></textFieldExpression>
            </textField>

        </band>
    </title>

    <detail>
        <band height="380">

            <staticText>
                <reportElement x="0" y="20" width="120" height="20"/>
                <textElement><font size="11" isBold="true"/></textElement>
                <text><![CDATA[Id:]]></text>
            </staticText>
            <textField isBlankWhenNull="true">
                <reportElement x="130" y="20" width="405" height="20"/>
                <textElement><font size="11"/></textElement>
                <textFieldExpression><![CDATA[$P{coverageId}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="0" y="60" width="120" height="20"/>
                <textElement><font size="11" isBold="true"/></textElement>
                <text><![CDATA[Nom:]]></text>
            </staticText>
            <textField isBlankWhenNull="true">
                <reportElement x="130" y="60" width="405" height="20"/>
                <textElement><font size="11"/></textElement>
                <textFieldExpression><![CDATA[$P{patientLastName}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="0" y="100" width="120" height="20"/>
                <textElement><font size="11" isBold="true"/></textElement>
                <text><![CDATA[Prenom:]]></text>
            </staticText>
            <textField isBlankWhenNull="true">
                <reportElement x="130" y="100" width="405" height="20"/>
                <textElement><font size="11"/></textElement>
                <textFieldExpression><![CDATA[$P{patientFirstName}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="0" y="140" width="120" height="20"/>
                <textElement><font size="11" isBold="true"/></textElement>
                <text><![CDATA[Status:]]></text>
            </staticText>
            <textField isBlankWhenNull="true">
                <reportElement x="130" y="140" width="405" height="20"/>
                <textElement><font size="11"/></textElement>
                <textFieldExpression><![CDATA[$P{status}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="0" y="180" width="120" height="20"/>
                <textElement><font size="11" isBold="true"/></textElement>
                <text><![CDATA[Date De Demande:]]></text>
            </staticText>
            <textField isBlankWhenNull="true">
                <reportElement x="130" y="180" width="405" height="20"/>
                <textElement><font size="11"/></textElement>
                <textFieldExpression><![CDATA[$P{demandeDate}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="0" y="220" width="120" height="20"/>
                <textElement><font size="11" isBold="true"/></textElement>
                <text><![CDATA[Date De Debut:]]></text>
            </staticText>
            <textField isBlankWhenNull="true">
                <reportElement x="130" y="220" width="405" height="20"/>
                <textElement><font size="11"/></textElement>
                <textFieldExpression><![CDATA[$P{startDate}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="0" y="260" width="120" height="20"/>
                <textElement><font size="11" isBold="true"/></textElement>
                <text><![CDATA[Date De Fin:]]></text>
            </staticText>
            <textField isBlankWhenNull="true">
                <reportElement x="130" y="260" width="405" height="20"/>
                <textElement><font size="11"/></textElement>
                <textFieldExpression><![CDATA[$P{endDate}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="0" y="300" width="120" height="20"/>
                <textElement><font size="11" isBold="true"/></textElement>
                <text><![CDATA[Cancereux:]]></text>
            </staticText>
            <textField isBlankWhenNull="true">
                <reportElement x="130" y="300" width="405" height="20"/>
                <textElement><font size="11"/></textElement>
                <textFieldExpression><![CDATA[$P{hasCancer}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="0" y="340" width="120" height="20"/>
                <textElement><font size="11" isBold="true"/></textElement>
                <text><![CDATA[Notes:]]></text>
            </staticText>
            <textField isBlankWhenNull="true" isStretchWithOverflow="true">
                <reportElement x="130" y="340" width="405" height="20"/>
                <textElement><font size="11"/></textElement>
                <textFieldExpression><![CDATA[$P{notes}]]></textFieldExpression>
            </textField>

        </band>
    </detail>

</jasperReport>
